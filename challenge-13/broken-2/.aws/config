# BUG: The profile name here is "deployment" but the Terraform provider
# references "deploy-role". These must match.
# Also: the source_profile references a profile that does not exist
# in the credentials file.

[profile deployment]
region = us-east-1
role_arn = arn:aws:iam::123456789012:role/DeploymentRole
source_profile = base-creds

[profile readonly]
region = us-east-1
role_arn = arn:aws:iam::123456789012:role/ReadOnlyRole
source_profile = base-creds
